# ============================================================
#  University Management System — Environment Configuration
# ============================================================
#
#  Copy this file to .env.local for local development:
#    cp .env.local.example .env.local
#
#  NEVER commit .env.local to version control.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/university-management-system

# MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<USER>:<PASSWORD>@<CLUSTER>.mongodb.net/university-management-system?retryWrites=true&w=majority

# ── NextAuth ──────────────────────────────────────────────────
# The full URL of your application (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Secret key — MUST be at least 32 random characters.
# Generate one with:   openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_32_CHAR_SECRET

# ── File storage: Cloudinary ──────────────────────────────────
# Required for document uploads. Get these from https://cloudinary.com dashboard.
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_API_SECRET
# Optional — upload folder (default: university-management-system/applications)
# CLOUDINARY_FOLDER=university-management-system/applications

# ── Application ───────────────────────────────────────────────
NODE_ENV=development

# Maximum file size for uploads (bytes). Default: 10485760 = 10 MB
# UPLOAD_MAX_BYTES=10485760

# ── Rate Limiting ─────────────────────────────────────────────
# Requests per IP per window (default: 100)
# RATE_LIMIT_MAX=100
# Window in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000
