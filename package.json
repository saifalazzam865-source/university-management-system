{
  "name": "university-management-system",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready full-stack university management platform — admissions, students, faculties, and admin panel.",
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "seed": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register scripts/seed.ts",
    "seed:prod": "NODE_ENV=production npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register scripts/seed.ts",
    "db:reset": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' -r tsconfig-paths/register scripts/reset.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "react": "^18",
    "react-dom": "^18",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5"
  }
}
