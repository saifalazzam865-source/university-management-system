# ============================================================
#  University Management System — Environment Variables
#
#  SETUP INSTRUCTIONS:
#  1. Copy this file:   cp .env.example .env.local
#  2. Fill in all values marked with <...>
#  3. NEVER commit .env.local to git (it's in .gitignore)
# ============================================================

# ── MongoDB ──────────────────────────────────────────────────
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/university-management-system?retryWrites=true&w=majority

# ── NextAuth ──────────────────────────────────────────────────
# The canonical URL of your deployment (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Secret key for signing JWTs — MUST be at least 32 random characters
# Generate one: openssl rand -base64 32
NEXTAUTH_SECRET=<replace-with-32+-character-random-string>

# ── File storage: Cloudinary ──────────────────────────────────
# Create a free account at https://cloudinary.com → Dashboard shows these.
# Required for document uploads in production (Vercel has no writable disk).
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
# Optional — folder uploads are organised under (defaults shown):
# CLOUDINARY_FOLDER=university-management-system/applications

# Optional — max upload size in bytes (defaults to 10 MB):
# UPLOAD_MAX_BYTES=10485760

# ── Application ───────────────────────────────────────────────
NODE_ENV=development
